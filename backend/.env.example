# Stellarator backend environment example.
# Copy to .env and fill in real values. Secrets must be at least 32 bytes.

# --- Core ----------------------------------------------------------------
STELLARATOR_DB_URL=sqlite+aiosqlite:////data/stellarator.db
# REQUIRED: random, >= 32 bytes. Boot will refuse "change-me" / blank.
STELLARATOR_SECRET=replace-with-a-random-32+byte-string-aaaaaaaa
# Key rotation: set to old STELLARATOR_SECRET value before changing the primary.
# Comma-separated for multiple generations. Remove after re-encrypting stored tokens.
STELLARATOR_SECRET_PREVIOUS=
# Comma-separated CORS origins. Use "*" only for local dev (loud warning).
STELLARATOR_CORS_ORIGINS=http://localhost:3000

# --- Tinker --------------------------------------------------------------
# Optional global fallback key. Per-agent keys set via PUT /v1/integrations/keys/tinker
# take precedence; if neither is set, run creation returns HTTP 412 tinker_key_missing.
TINKER_API_KEY=
TINKER_BASE_URL=https://api.tinker.thinkingmachines.ai/v1

# --- Agent bearer tokens (constant-time matched) -------------------------
AGENT_TOKEN_CLAUDE_CODE=
AGENT_TOKEN_OPENAI=
AGENT_TOKEN_CODEX=

# --- OpenAI / Codex ------------------------------------------------------
OPENAI_API_KEY=
CODEX_OAUTH_CLIENT_ID=
CODEX_OAUTH_CLIENT_SECRET=
# If unset, /v1/oauth/codex/start derives the redirect URI via request.url_for.
CODEX_OAUTH_REDIRECT_URI=

# --- OpenAI browser OAuth — DEPRECATED: Codex sign-in covers OpenAI access --
# These vars are kept so existing deployments load without errors, but the
# /v1/oauth/openai/* routes are no longer registered. Use Codex sign-in instead.
# DEPRECATED — Codex sign-in covers OpenAI access
# OPENAI_OAUTH_CLIENT_ID=
# OPENAI_OAUTH_CLIENT_SECRET=
# OPENAI_OAUTH_AUTH_URL=https://auth.openai.com/oauth/authorize
# OPENAI_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
# OPENAI_OAUTH_REDIRECT_URI=
# OPENAI_OAUTH_SCOPES=openid email offline_access

# --- OpenRouter etiquette headers ----------------------------------------
# Sent with every OpenRouter request so the router can attribute traffic.
OPENROUTER_REFERER=https://stellarator.dev
OPENROUTER_TITLE=Stellarator

# --- Supervisor handoff (Rust side will validate) ------------------------
SUPERVISOR_SHARED_SECRET=

# --- Reconciliation ------------------------------------------------------
# Base interval in seconds between reconciliation passes. Default: 30.
# Actual sleep grows exponentially (capped at 300s) on consecutive supervisor failures.
STELLARATOR_RECONCILE_INTERVAL_SECS=30

# --- Cost defaults -------------------------------------------------------
COST_H100_USD_PER_HR=4.50
COST_A100_USD_PER_HR=2.20
STELLARATOR_RATE_LIMIT_STORAGE=  # Optional: redis://host:6379/0 for multi-worker accuracy
WEB_CONCURRENCY=1  # uvicorn workers — keep =1 unless rate-limit storage is set

# --- ML Intern loop ------------------------------------------------------
# Optional GitHub Personal Access Token (classic; public_repo scope) used by
# the research sub-agent's github_find_examples / github_read_file tools.
# Unauth fallback caps at ~10 req/min; with a token, search ~30 req/min and
# contents ~5000 req/hr.
GITHUB_TOKEN=
# Internal base URL the research sub-agent uses for /v1 tool dispatch. In
# production set this to the in-cluster service URL; default is localhost.
STELLARATOR_INTERNAL_BASE_URL=http://localhost:8000
